{
    "name": "fabricadanet/sistesdafabrica",
    "description": "Projeto saas de criação de sites para PME",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "authors": [
        {
            "name": "Fábrica da Net"
        }
    ],
    "require": {
        "ext-pdo": "*",
        "symfony/html-sanitizer": "^8.1"
    },
    "scripts": {
        "dev": "php -S 0.0.0.0:8000 -t public",
        "migrate": "php database/migrate.php migrate",
        "rollback": "php database/migrate.php rollback",
        "seed": "php database/migrate.php seed",
        "fresh": "php database/migrate.php fresh",
        "reset": "php database/reset.php"
    }
}
